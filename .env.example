# Copie este arquivo para .env e preencha os valores.
# O .env é carregado automaticamente pelo pipeline (python-dotenv) e está no .gitignore.

# Obrigatória para a etapa de carga: string de conexão do PostgreSQL
# (Supabase, Railway ou instância local).
# Formato: postgresql://usuario:senha@host:5432/nome_do_banco
DATABASE_URL=

# Opcional: URL base da API da Remotive. Se omitida, usa o endpoint público padrão.
REMOTIVE_API_URL=https://remotive.com/api/remote-jobs
