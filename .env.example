# Copy this file to .env and fill in the values.
# The .env file is loaded automatically by the pipeline (python-dotenv) and is gitignored.

# Required for the load step: PostgreSQL connection string
# (Supabase, Railway or a local instance).
# Also read by the Streamlit dashboard — when unset (or unreachable) the
# dashboard runs in demo mode on the bundled sample data.
# Format: postgresql://user:password@host:5432/database_name
DATABASE_URL=

# Optional: Remotive API base URL. If omitted, the default public endpoint is used.
REMOTIVE_API_URL=https://remotive.com/api/remote-jobs

# Optional: RemoteOK API base URL. If omitted, the default public endpoint is used.
REMOTEOK_API_URL=https://remoteok.com/api

# Required for the Adzuna extraction: register a free application at
# https://developer.adzuna.com/ to get both values.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Optional: country for Adzuna job searches (two-letter code, e.g. gb or us).
# If omitted, defaults to gb (Adzuna's home market, deepest job coverage).
ADZUNA_COUNTRY=gb

# Optional: Adzuna API base URL. If omitted, the default public endpoint is used.
ADZUNA_API_URL=https://api.adzuna.com/v1/api/jobs

# --- dbt (transform/) -------------------------------------------------------
# dbt-postgres does not accept a single connection string, so these mirror the
# components of DATABASE_URL. NOTE: dbt does not read .env files — export
# these in your shell before running dbt (or use your own env loader).
# Defaults (in transform/profiles.yml): localhost / 5432 / postgres / '' /
# remoteradar / analytics.
DBT_PG_HOST=
DBT_PG_PORT=5432
DBT_PG_USER=
DBT_PG_PASSWORD=
DBT_PG_DBNAME=
# Schema where dbt materializes the models (staging views included).
DBT_PG_SCHEMA=analytics
